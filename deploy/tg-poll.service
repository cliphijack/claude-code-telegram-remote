[Unit]
Description=Telegram remote control poller for Claude Code
Documentation=https://github.com/etinpres/claude-code-telegram-remote
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=__PYTHON__ %h/.claude/channels/telegram/tg_poll.py
WorkingDirectory=%h/.claude/channels/telegram
Restart=on-failure
RestartSec=5
StandardOutput=append:%h/.claude/channels/telegram/systemd.out.log
StandardError=append:%h/.claude/channels/telegram/systemd.err.log

# Hardening
NoNewPrivileges=true
# PrivateTmp must remain false: tmux uses a Unix socket under
# /tmp/tmux-<uid>/, and a private /tmp namespace prevents the poller
# from reaching it (`error connecting to /tmp/tmux-1000/default`).
PrivateTmp=false
ProtectSystem=strict
ReadWritePaths=%h/.claude/channels/telegram

[Install]
WantedBy=default.target
