# Telegram bot credentials — see README for how to obtain these.
# Copy this file to `.env` and fill in the values.

# Bot token from @BotFather (https://t.me/BotFather /newbot).
TELEGRAM_BOT_TOKEN=

# Chat ID to send responses to. Get it by messaging @userinfobot
# (https://t.me/userinfobot) from the account you want to use.
TELEGRAM_CHAT_ID=

# tmux target in `session:window.pane` form. Run `tmux list-panes -a` to find it.
# The poller injects slash commands and key sequences into this pane.
TMUX_TARGET=0:0.0

# Comma-separated Telegram user IDs allowed to control the bot.
# Must match the TELEGRAM_CHAT_ID owner at minimum. Empty value = fail-secure (all blocked).
# Set ALLOW_ANY=1 to explicitly disable the allowlist (not recommended).
ALLOWED_USER_IDS=
