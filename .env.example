# ─────────────────────────────────────────────────────────────────────────────
# Telegram remote control — environment variables
# ─────────────────────────────────────────────────────────────────────────────
# 이 파일을 `.env`로 복사해서 값 채운 뒤 ./install.sh 재실행.
#   cp .env.example .env && chmod 600 .env && $EDITOR .env
#
# 설치 전체 가이드: README.md 참고.
# ─────────────────────────────────────────────────────────────────────────────


# ── 1. TELEGRAM_BOT_TOKEN ────────────────────────────────────────────────────
# 텔레그램 봇 토큰. 절대 외부 공유 금지 — 토큰 유출 = 봇 완전 탈취.
#
# 발급법:
#   1. 텔레그램에서 @BotFather (https://t.me/BotFather) 대화 시작
#   2. /newbot 전송 → 봇 이름, username 입력
#   3. 응답 중 "123456789:ABC-DEF..." 형식의 HTTP API 토큰 복사
#
# 형식: "<숫자>:<문자>" (콜론 포함). 공백·따옴표·주석 붙이지 말 것.
# 유출 시 BotFather에게 /token → /revoke 로 즉시 재발급.
TELEGRAM_BOT_TOKEN=


# ── 2. TELEGRAM_CHAT_ID ──────────────────────────────────────────────────────
# 봇이 답장을 보낼 chat ID. 본인 계정 기준 = 본인 user ID와 동일.
#
# 확인법:
#   1. 봇에게 아무 메시지나 먼저 보내기 (미전송 시 봇이 답장 못 함)
#   2. 텔레그램에서 @userinfobot (https://t.me/userinfobot) 대화
#   3. 응답 중 "Id: 123456789"의 숫자 복사
#
# 그룹/채널 봇이면 음수일 수 있음 (예: -1001234567890). 개인 봇은 양수.
TELEGRAM_CHAT_ID=


# ── 3. TMUX_TARGET ───────────────────────────────────────────────────────────
# Claude Code CLI가 돌아가는 tmux pane 주소 (session:window.pane 형식).
#
# 확인법 (Claude Code를 tmux 안에서 실행 중인 상태에서):
#   tmux list-panes -a
# 출력 예: "myproj:0.0: [80x24] [history 0/2000, 0 bytes] %2 (active)"
# → 복사할 값: "myproj:0.0"
#
# 가장 단순한 세션이면 보통 "0:0.0". tmux 밖에서 Claude Code 돌리면 이 도구
# 자체가 무의미 — 먼저 `tmux new -s myproj` 하고 그 안에서 claude 실행.
TMUX_TARGET=0:0.0


# ── 4. ALLOWED_USER_IDS ──────────────────────────────────────────────────────
# 봇을 제어할 수 있는 텔레그램 user ID 화이트리스트 (콤마 구분).
#
# 비워두면 fail-secure = 아무도 못 씀 (권장 기본값).
# 본인 user ID만 등록하는 게 기본. 여러 명이면: "111111,222222,333333"
#
# user ID는 TELEGRAM_CHAT_ID와 같음 (개인 봇 기준).
# 화이트리스트 완전 비활성화(비권장): ALLOW_ANY=1 을 별도 변수로 추가.
ALLOWED_USER_IDS=
